{
  "name": "runtime-aliases",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/runtime-aliases/src",
  "projectType": "library",
  "release": {
    "version": {
      "manifestRootsToUpdate": [
        "dist/{projectRoot}"
      ],
      "currentVersionResolver": "git-tag",
      "fallbackCurrentVersionResolver": "disk"
    }
  },
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/libs/runtime-aliases",
        "main": "libs/runtime-aliases/src/index.ts",
        "tsConfig": "libs/runtime-aliases/tsconfig.lib.json",
        "assets": [
          "libs/runtime-aliases/*.md",
          {
            "input": "libs/runtime-aliases/src/bin",
            "glob": "**/*",
            "output": "src/bin"
          }
        ],
        "format": ["cjs"]
      }
    },
    "nx-release-publish": {
      "options": {
        "packageRoot": "dist/{projectRoot}"
      }
    }
  }
}